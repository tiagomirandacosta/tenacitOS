# Autenticação (gerar hash: node -e "require('bcryptjs').hash('SUA_SENHA',12).then(console.log)")
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here

# OpenClaw paths (OPENCLAW_DIR is the main one — sets all paths automatically)
OPENCLAW_DIR=/docker/moltbot/openclaw-data

# Docker (used by tasks that call docker exec — added in setup Tasks 4-5)
DOCKER_CONTAINER=moltbot-clawdbot-1
OPENCLAW_SKILLS_PATH=/home/node/clawd/skills

# Session signing (required for auth cookies)
AUTH_SECRET=generate-with-openssl-rand-hex-32

# Branding
NEXT_PUBLIC_AGENT_NAME=Mission Control
NEXT_PUBLIC_APP_TITLE=Mission Control
